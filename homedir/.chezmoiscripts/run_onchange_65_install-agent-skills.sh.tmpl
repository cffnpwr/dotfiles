#!/usr/bin/env bash
# apm.yml hash: {{ include "dot_apm/apm.yml" | sha256sum }}
set -euo pipefail

# apm マニフェスト(~/.apm/apm.yml)で宣言した公開スキルを導入する。
# apm 本体の導入はパッケージ段階の責務のため、ここでは導入しない。
# 上のハッシュコメントでマニフェスト本文の変化(宣言スキルの増減・
# ピン留め ref の変更)を run_onchange が検知して再インストールする。
# パッケージ段(40)で導入した apm 本体に依存し、fetch 段(60)の後に走る。

# apm 未導入なら段階をスキップする。
if ! command -v apm >/dev/null 2>&1; then
  echo "apm: not installed; skipping agent skill installation" >&2
  exit 0
fi

# user scope のマニフェスト(~/.apm/apm.yml)を読み、user scope へ導入する。
apm install --global
