#!/usr/bin/env bash
set -euo pipefail
{{ includeTemplate "path.sh" . }}

# パスフレーズ暗号化された age 鍵を復号し、所定の位置へ配置する。
# encrypted_ ファイルの適用より前に走らせるため before とする。
# 暗号鍵本文を includeTemplate で展開し、その変化(鍵のローテーション)を run_onchange が検知して再復号する。

key="{{ joinPath .chezmoi.homeDir ".config/chezmoi/key.txt" }}"
mkdir -p "$(dirname "$key")"
umask 077
"$CHEZMOI_EXECUTABLE" age decrypt --passphrase --output "$key" <<'EOF'
{{ includeTemplate "key.txt.age" }}
EOF
chmod 600 "$key"
