{{ if eq .os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

# パッケージ状態フィンガープリント。変化時にrun_onchangeが本スクリプトを再実行する。
{{ includeTemplate "darwin-package-state.tmpl" . }}

# brew のパスを解決する。
brew_path() {
  if command -v brew >/dev/null 2>&1; then
    command -v brew
  elif [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    printf '%s\n' "${HOMEBREW_PREFIX}/bin/brew"
  else
    printf '%s\n' "/opt/homebrew/bin/brew"
  fi
}

brew_bin="$(brew_path)"
eval "$("$brew_bin" shellenv)"

# 宣言formula
declared_formulae=(
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if and (eq $d.method "brew") (not (default false (get $d "cask"))) }}
  {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- end }}
{{- end }}
)

# 宣言cask
declared_casks=(
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if and (eq $d.method "brew") (default false (get $d "cask")) }}
  {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- end }}
{{- end }}
)

# クリーンアップ除外glob
ignore_patterns=(
{{- range (default (list) (get .ignore "darwin")) }}
  {{ . | quote }}
{{- end }}
)

# サードパーティtapをtrust登録する(未信頼tapはbundleのロード時にスキップされるため)。
trusted_taps=""
for name in ${declared_formulae[@]+"${declared_formulae[@]}"} ${declared_casks[@]+"${declared_casks[@]}"}; do
  [[ "$name" == */*/* ]] || continue
  tap="${name%/*}"
  [[ " $trusted_taps " == *" $tap "* ]] && continue
  brew trust --tap "$tap"
  trusted_taps="$trusted_taps $tap"
done

# Brewfileを生成しstdin経由で適用
brew bundle --file=- <<'BREWFILE'
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if eq $d.method "brew" }}
{{- if default false (get $d "cask") }}
cask {{ (default .name (get $d "name")) | quote }}
{{- else }}
brew {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- else if eq $d.method "mas" }}
mas {{ (default .name (get $d "name")) | quote }}, id: {{ $d.id }}
{{- end }}
{{- end }}
{{- end }}
BREWFILE

matches_ignore() {
  local name="$1" pat
  for pat in ${ignore_patterns[@]+"${ignore_patterns[@]}"}; do
    # shellcheck disable=SC2053
    if [[ "$name" == $pat ]]; then
      return 0
    fi
  done
  return 1
}

# tap接頭辞を除いた短名。brew leaves / brew list --cask の出力と宣言名を揃える。
short_name() {
  printf '%s\n' "${1##*/}"
}

is_declared_formula() {
  local name="$1" elem
  for elem in ${declared_formulae[@]+"${declared_formulae[@]}"}; do
    if [[ "$name" == "$(short_name "$elem")" ]]; then
      return 0
    fi
  done
  return 1
}

is_declared_cask() {
  local name="$1" elem
  for elem in ${declared_casks[@]+"${declared_casks[@]}"}; do
    if [[ "$name" == "$(short_name "$elem")" ]]; then
      return 0
    fi
  done
  return 1
}

# formulaクリーンアップ(leavesは完全名で返るため短名化して照合する)
while IFS= read -r name; do
  [[ -z "$name" ]] && continue
  if is_declared_formula "$(short_name "$name")"; then
    continue
  fi
  if matches_ignore "$name"; then
    continue
  fi
  brew uninstall "$name"
done < <(brew leaves --installed-on-request)

# caskクリーンアップ
while IFS= read -r name; do
  [[ -z "$name" ]] && continue
  if is_declared_cask "$(short_name "$name")"; then
    continue
  fi
  if matches_ignore "$name"; then
    continue
  fi
  brew uninstall --cask "$name"
done < <(brew list --cask -1)

# 不要な依存を除去
brew autoremove
{{- end }}
