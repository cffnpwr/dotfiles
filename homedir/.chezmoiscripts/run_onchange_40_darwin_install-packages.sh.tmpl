{{ if eq .os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail
{{ includeTemplate "path.sh" . }}

{{ includeTemplate "log.sh" }}
STEP="install-packages"
log "applying macOS packages (brew)"

# パッケージ状態フィンガープリント。変化時にrun_onchangeが本スクリプトを再実行する。
{{ includeTemplate "darwin-package-state.tmpl" . }}

# brew のパスを解決する。
brew_path() {
  if command -v brew >/dev/null 2>&1; then
    command -v brew
  elif [[ -n "${HOMEBREW_PREFIX:-}" && -x "${HOMEBREW_PREFIX}/bin/brew" ]]; then
    printf '%s\n' "${HOMEBREW_PREFIX}/bin/brew"
  else
    printf '%s\n' "/opt/homebrew/bin/brew"
  fi
}

brew_bin="$(brew_path)"
eval "$("$brew_bin" shellenv)"

# 宣言formula
declared_formulae=(
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if and (eq $d.method "brew") (not (default false (get $d "cask"))) }}
  {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- end }}
{{- end }}
)

# 宣言cask
declared_casks=(
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if and (eq $d.method "brew") (default false (get $d "cask")) }}
  {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- end }}
{{- end }}
)

# クリーンアップ除外glob
ignore_patterns=(
{{- range (default (list) (get .ignore "darwin")) }}
  {{ . | quote }}
{{- end }}
)

# サードパーティtapをtrust登録する(未信頼tapはbundleのロード時にスキップされるため)。
trusted_taps=""
for name in ${declared_formulae[@]+"${declared_formulae[@]}"} ${declared_casks[@]+"${declared_casks[@]}"}; do
  [[ "$name" == */*/* ]] || continue
  tap="${name%/*}"
  [[ " $trusted_taps " == *" $tap "* ]] && continue
  brew trust --tap "$tap"
  trusted_taps="$trusted_taps $tap"
done

matches_ignore() {
  local name="$1" pat
  for pat in ${ignore_patterns[@]+"${ignore_patterns[@]}"}; do
    # shellcheck disable=SC2053
    if [[ "$name" == $pat ]]; then
      return 0
    fi
  done
  return 1
}

# 未宣言パッケージを一括削除する。
# $1: ログ用ラベル, $2: brew uninstallの追加フラグ(空 or --cask), 残り: 宣言済み名。
# インストール済み一覧はstdinから1行1名で受ける。tap接頭辞を除いた短名で宣言名と照合する。
cleanup_undeclared() {
  local label="$1" uninstall_flag="$2"
  shift 2
  local declared=("$@")
  local name elem to_remove=()
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    matches_ignore "$name" && continue
    for elem in ${declared[@]+"${declared[@]}"}; do
      if [[ "${name##*/}" == "${elem##*/}" ]]; then
        continue 2
      fi
    done
    to_remove+=("$name")
  done
  [[ ${#to_remove[@]} -eq 0 ]] && return 0
  log "removing undeclared ${label}: ${to_remove[*]}"
  if [[ -n "$uninstall_flag" ]]; then
    brew uninstall "$uninstall_flag" "${to_remove[@]}"
  else
    brew uninstall "${to_remove[@]}"
  fi
}

# 競合するパッケージの入れ替え時、旧パッケージが残ったままだと新パッケージのインストールが
# 競合で失敗するため、bundleでのインストールより前に未宣言パッケージを削除する。
log "cleaning up undeclared formulae"
cleanup_undeclared "formulae" "" ${declared_formulae[@]+"${declared_formulae[@]}"} < <(brew leaves --installed-on-request)

log "cleaning up undeclared casks"
cleanup_undeclared "casks" "--cask" ${declared_casks[@]+"${declared_casks[@]}"} < <(brew list --cask -1)

# clone元の明示が要るtap(private tapなど)のtap登録行を構築する。
# brew bundleの暗黙auto-tapはHTTPSのため、urlを与えたものはBrewfileにtap行を明示生成する。
{{- $tap_lines := list }}
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if and (eq $d.method "brew") (get $d "url") }}
{{- $parts := splitList "/" (default .name (get $d "name")) }}
{{- $tap := printf "%s/%s" (index $parts 0) (index $parts 1) }}
{{- $tap_lines = append $tap_lines (printf "tap %s, %s" ($tap | quote) ($d.url | quote)) }}
{{- end }}
{{- end }}
{{- end }}

# Brewfileを生成しstdin経由で適用
log "installing declared packages (brew bundle)"
brew bundle --file=- <<'BREWFILE'
{{- range ($tap_lines | uniq) }}
{{ . }}
{{- end }}
{{- range .packages }}
{{- if hasKey . "darwin" }}
{{- $d := .darwin }}
{{- if eq $d.method "brew" }}
{{- if default false (get $d "cask") }}
cask {{ (default .name (get $d "name")) | quote }}
{{- else }}
brew {{ (default .name (get $d "name")) | quote }}
{{- end }}
{{- else if eq $d.method "mas" }}
mas {{ (default .name (get $d "name")) | quote }}, id: {{ $d.id }}
{{- end }}
{{- end }}
{{- end }}
BREWFILE

# 不要な依存を除去
log "removing unused dependencies (brew autoremove)"
brew autoremove
{{- end }}
